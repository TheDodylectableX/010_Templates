//------------------------------------------------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: MAP.bt
//   Authors: Dodylectable
//   Version: 1.0
//   Purpose: Reverse engineering Tomb Raider: Angel of Darkness Remastered's texture lists
//  Category: File Lists
// File Mask: *.MAP
//  ID Bytes: 
//   History: 
//------------------------------------------------------------------------------------------

// The textures are inside the TEX folder.
// Each entry is 16 bytes long but most textures are 15 characters long only.

//------------------------------------------------------------------------------------------

typedef struct { uint TextureCount; } Header <name="Header", read=Str("%d Textures", this.TextureCount)>;

typedef struct { char TextureName[16]; } Texture <name="Texture", read=Str("%s.DDS", this.TextureName)>;

//------------------------------------------------------------------------------------------

struct {
    Header header;
    if (header.TextureCount > 0) Texture texture[header.TextureCount] <optimize=false>;
} MAP <name="Tomb Raider: Angel of Darkness Remastered .MAP File">;

//------------------------------------------------------------------------------------------
