//---------------------------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: CHR.bt
//   Authors: Dodylectable, Violet
//   Version: 1.0
//   Purpose: Reverse engineering TR: Angel of Darkness' 3D models
//  Category: Models
// File Mask: *.CHR
//  ID Bytes: 00 00 00 00
//   History: 
//---------------------------------------------------------------------

LittleEndian();
#include "../Common.bt"

typedef struct {
    VEC4F Origin;
    float Radius;
    FSkip(12); // Padding
} COLLIDESPHERE;

typedef enum <ushort> { // Padded byte entry
  DRAWPT_POINTLIST = 0x1,
  DRAWPT_LINELIST = 0x2,
  DRAWPT_LINESTRIP = 0x3,
  DRAWPT_TRIANGLELIST = 0x4,
  DRAWPT_TRIANGLESTRIP = 0x5,
  DRAWPT_TRIANGLEFAN = 0x6,
} DRAW_PRIMITIVETYPE;

//---------------------------------------------------------------------

typedef struct {
    uint Magic;
    uint textureDataOffset <name="Texture Data Offset">;
    uint skeletonDataOffset <name="Skeleton Data Offset">;
    uint Unknown;
    uint primaryMeshDataOffset <name="Primary Mesh Data Data Offset">;
    uint boneCount <name="Bone Count">;
} Header <name="Header">;

typedef struct (uint boneCount) {
    struct {
        int boneFlags <name="Bone Flags">;
        char boneName[64] <name="Bone Name">;
        int boneID <name="Bone ID">;
        int boneIndex <name="Bone Index">;
        int matrixIndex <name="Bone Matrix Index">;
        VEC4F bindPose[4] <name="Bone Bind Pose">;
        VEC4F absoluteBind[4] <name="Bone Absolute Bind Pose">;
        VEC4F preTransform[4] <name="Bone Pre-Transform Pose">;
        VEC4F postTransform[4] <name="Bone Post-Transform Pose">;
        COLLIDESPHERE sphere <name="Collide Sphere">;
        int physicsFlags <name="Physics Flags">;
        uint parentBone <name="Bone Parnet">;
        FSkip(72); // Padding
    } Bone[boneCount] <read=boneName, optimize=false>;
} SkeletonData;

//---------------------------------------------------------------------

typedef struct {
    VEC3SS primaryPositions <name="Primary Positions">;
    VEC3SS secondaryPositions <name="Secondary Positions">;
    VEC3SB primaryNormals <name="Primary Normals">;
    VEC3SB secondaryNormals <name="Secondary Normals">;
    VEC3SB primaryTangents <name="Primary Tangents">;
    VEC3SB primaryBinormals <name="Primary Binormals">;
    VEC3SB secondaryTangents <name="Secondary Tangents">;
    VEC3SB secondaryBinormals <name="Secondary Binormals">;
    short BoneWeight <name="Bone Weights">;
    ubyte BoneIndices[2] <name="Bone Indices">;
    VEC2SS UV;
} SYS_D3D_SKIN__VECTOR_WEIGHTED;

typedef struct {
    VEC3SS Positions;
    VEC3SB Normals;
    VEC3SB Tangents;
    VEC3SB Binormals;
    VEC2SS UV;
} SYS_D3D_SKIN__VECTOR_RIGGED;

typedef struct {
    uint faceCount <name="Face Count">;
    ushort Indices[faceCount];
} IndicesData;

typedef struct {
    uint numRuns;
    struct Elements {  
        short primitiveCount <name="Primitive Count">;
        short faceCount <name="Face Count">;
        short indicesStart <name="Face Index Start">;
        ushort materialIndex <name="Material Index">;
        short textureBumpIndex <name="Texture Bump Index">;
        DRAW_PRIMITIVETYPE faceType <name="Face Type">;
    } runs[numRuns];
} RunData;

typedef struct {
    int Unknown;
    uint skinID <name="Skin ID">;
    uint vertexCount <name="Vertex Count">;
    SYS_D3D_SKIN__VECTOR_WEIGHTED vertices[vertexCount];
    IndicesData Faces;
    RunData runData;
} SkinData;

typedef struct {
    int Unknown;
    int meshFlags <name="Mesh Flags">;
    int meshID <name="Mesh Hash", format=hex>;
    int indexBone <name="Mesh Index Bone">;
    int indexAnimationBone <name="Mesh Index Animation Bone">;
    int vertexCount <name="Vertex Count">;
    SYS_D3D_SKIN__VECTOR_RIGGED Vertices[vertexCount]<optimize=false>;
    IndicesData Faces;
    RunData runData;
} RiggedData;

typedef struct {
    uint Unknown;
    SkinData skinData;
} Mesh1;

typedef struct {
    uint numChildren <name="Mesh Count">;
    RiggedData riggedData[numChildren] <optimize=false>;
} Mesh2;

//---------------------------------------------------------------------

struct TextureData {
    uint materialCount <name="Material Count">;
    struct Material {
        int textureFlags <name="Texture Flags">;
        int textureCount <name="Texture Count">;
        int indexTextures[textureCount];
    } materials[materialCount] <name="Material", optimize=false>;
    
    uint textureCount <name="Texture Count">;
    struct Texture { // This entire section is unused by the remaster.
        char textureFormat[4] <name="Texture Format", comment="ARGB if empty.">;
        uint textureUse;
        uint frameCount <name="Texture Frame Count">;
        uint mipMapCount <name="Texture Mip Map Count">;
        uint textureWidth <name="Texture Width">;
        uint textureHeight <name="Texture Height">;
        uint textureSize <name="Texture Size">;
        ubyte textureData[textureSize] <name="Texture Data">;
    } textures[textureCount] <name="Texture", read=textureFormat, optimize=false>;
};

//---------------------------------------------------------------------

struct {
    Header header;

    FSeek(header.skeletonDataOffset);
    SkeletonData skeleton(header.boneCount) <name="Skeleton", optimize=false>;

    FSeek(header.primaryMeshDataOffset);
    Mesh1 mesh1Data <name="Primary Mesh Data", optimize=false>;
    Mesh2 mesh2Data <name="Secondary Mesh Data", optimize=false>;

    FSeek(header.textureDataOffset);
    TextureData textureData <name="Material and Texture Data", optimize=false>;
} CHR <name="Tomb Raider: Angel of Darkness (Remastered) .CHR Model">;

//---------------------------------------------------------------------
