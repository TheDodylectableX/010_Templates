//---------------------------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: TMT.bt
//   Authors: Dodylectable, Nakamichi680
//   Version: 1.0
//   Purpose: Reverse engineering TR: Angel of Darkness' morph targets
//  Category: Models
// File Mask: *.TMT
//  ID Bytes: 4D 50 48 42
//   History: 
//---------------------------------------------------------------------

// The file format stores data grouped sequentially by vertex. (Interleaved)
// A single vertex block contains data for the Base Mesh (0) + All Morphs. (morphTargetCount)
// - For Vertex 0, It lists its base position first then Morph 1 until the 8th final one then it moves to Vertex 1 and repeats.
// - Index 0 is always the base mesh. (Absolute Coordinates)
// - Index [n > 0] are the blendshapes. (Delta offsets from the base mesh)

LittleEndian();
#include "../Common.bt"

//---------------------------------------------------------------------

typedef struct {
    char Magic[4];
    ubyte headerSize <name="Header Size">;
    ushort unusedVertexCount <name="Unused Vertex Count", comment="Game doesn't seem to use this">;
    FSkip(1); // Padding
    uint TMTHash <name="TMT Hash", format=hex>;
    uint linkedSubmeshHash <name="Linked Submesh Hash", comment="This corresponds to a submesh inside the companion .CHR file", format=hex>;
    uint morphTargetCount <name="Morph Target Count">;
    uint vertexCount <name="Vertex Count", comment="Per morph target">;
    uint Unknown <comment="Always 0x18000000">;
    FSkip(4); // Padding
} Header <name="Header", read=Str("Hash: 0x%X | Linked Submesh: 0x%X | %d Morph Targets | %d Vertices", this.TMTHash, this.linkedSubmeshHash, this.morphTargetCount, this.vertexCount)>;

typedef struct {
    VEC3F Positions;
    VEC3F Normals;
    VEC2F UV;
} TMT_VertexData <read=Str("Position: (%.4f, %.4f, %.4f)", this.Positions.X, this.Positions.Y, this.Positions.Z)>;

typedef struct (int totalMorphTargetCount) {
    TMT_VertexData Morph[totalMorphTargetCount] <optimize=false>;
} VertexBlock <name="Vertex", read=Str("Base Position: (%.4f, %.4f, %.4f)", this.Morph[0].Positions.X, this.Morph[0].Positions.Y, this.Morph[0].Positions.Z)>;

//---------------------------------------------------------------------

struct {
    Header header <bgcolor=cLtPurple>;
    local int totalMorphTargetCount <hidden=true> = header.morphTargetCount + 1;
    VertexBlock Vertices(totalMorphTargetCount)[header.vertexCount] <bgcolor=cLtBlue, optimize=false>;
} TMT <name="Tomb Raider: Angel of Darkness .TMT File">;

//---------------------------------------------------------------------
